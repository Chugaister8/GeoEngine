{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "GEOENGINE_*"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs":   ["dist/**", ".next/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache":     false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs":   ["coverage/**"]
    }
  }
}
