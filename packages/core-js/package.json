{
  "name": "@geoengine/core-js",
  "version": "0.1.0",
  "description": "GeoEngine — JavaScript/TypeScript core (WebGPU renderer)",
  "main":   "./dist/index.js",
  "module": "./dist/index.mjs",
  "types":  "./dist/index.d.ts",
  "exports": {
    ".": {
      "import":  "./dist/index.mjs",
      "require": "./dist/index.js",
      "types":   "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build":     "tsup src/index.ts --format esm,cjs --dts --external three",
    "dev":       "tsup src/index.ts --format esm,cjs --dts --watch --external three",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@geoengine/shared-types": "workspace:*",
    "three": "^0.165.0"
  },
  "devDependencies": {
    "@types/three": "^0.165.0",
    "tsup":         "^8.0.0",
    "typescript":   "^5.4.0"
  },
  "peerDependencies": {
    "three": "^0.165.0"
  },
  "license": "MIT"
}
