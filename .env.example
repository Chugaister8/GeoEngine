# GeoEngine — Environment Variables
# Скопіюй у .env та заповни значення
# cp .env.example .env

# ================================================================
# SERVER
# ================================================================

# Режим debug (true = verbose logs, Swagger UI)
GEOENGINE_DEBUG=false

# Рівень логування: DEBUG | INFO | WARNING | ERROR
GEOENGINE_LOG_LEVEL=INFO

# JSON логи для продакшену (Loki/ELK)
GEOENGINE_JSON_LOGS=false

# CORS origins (JSON масив)
GEOENGINE_CORS_ORIGINS=["http://localhost:3000"]

# Workers
TERRAIN_WORKERS=4
ANALYSIS_WORKERS=2

# ================================================================
# DEM API KEYS
# ================================================================

# OpenTopography API ключ (для SRTM, Copernicus)
# Реєстрація: https://opentopography.org/developers
# JSON формат: {"copernicus25": "your_key", "srtm30": "your_key"}
GEOENGINE_DEM_API_KEYS={}

# Mapbox токен (для satellite tiles)
MAPBOX_TOKEN=

# MapTiler ключ (альтернатива Mapbox)
MAPTILER_KEY=

# ================================================================
# CACHE
# ================================================================

# Redis URL
GEOENGINE_REDIS_URL=redis://localhost:6379/0

# Директорія DEM кешу (disk)
GEOENGINE_DEM_CACHE_DIR=~/.geoengine/dem_cache

# ================================================================
# VIEWER (Next.js)
# ================================================================

# WebSocket URL до Python сервера
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# REST API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# ================================================================
# DOCKER
# ================================================================

# Build target: production | development
BUILD_TARGET=production

# Node environment
NODE_ENV=production

# Viewer external URL (для CORS)
VIEWER_URL=http://localhost:3000
